<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>
        <section name="socketServer" type="SuperSocket.SocketEngine.Configuration.SocketServiceConfig, SuperSocket.SocketEngine"/>
    </configSections>
    <appSettings>
        <add key="ServiceName" value="GPRSSocketServer"/>
    </appSettings>
    <socketServer>
        <servers>
            <server name="GPRSSocketTCPServer" serviceName="GPRSSocketService"
                    ip="Any" port="8818" mode="Async" maxConnectionNumber="10000">
            </server>          
        </servers>
        <services>
            <service name="GPRSSocketService"
                     type="SuperSocket.QuickStart.GPRSSocketServer.GPRSServer, SuperSocket.QuickStart.GPRSSocketServer" />
        </services>
    </socketServer>
    <startup>
        <!--
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0" />
        -->
      <supportedRuntime version="v2.0.50727" sku=".NETFramework,Version=v3.5" />
    </startup>
</configuration>