<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
      <section name="superSocket" type="SuperSocket.SocketEngine.Configuration.SocketServiceConfig, SuperSocket.SocketEngine"/>
  </configSections>
  <connectionStrings>
    <add name="connStr" connectionString="User Id=root;host=127.0.0.1;Database=tourdb;password=494211;port=3306;persist security info=True;character set=utf8;" providerName="MySql.Data.MySqlClient"/>
  </connectionStrings>
  <appSettings>
    <add key="ServiceName" value="GPSSocketServer"/>
  </appSettings>
  <superSocket>
    <servers>
      <server name="GPSSocketServer"
              serverTypeName="GPSSocketService"
              ip="Any"
              mode="Tcp"
              port="8815"
              maxConnectionNumber="10000"
              sendingQueueSize="1024"
              sendBufferSize="10240"
              maxRequestLength="10240"
              receiveBufferSize="10240"
              >
      </server>
    </servers>
    <serverTypes>
        <add name="GPSSocketService" type="SuperSocket.QuickStart.GPSSocketServer.GPSServer, SuperSocket.QuickStart.GPSSocketServer" />
    </serverTypes>
  </superSocket>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0" />
  </startup>
  <runtime>
    <gcServer enabled="true" />
  </runtime>
</configuration>