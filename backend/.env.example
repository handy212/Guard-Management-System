# Django
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_ENV=development

# Auth (token lifetime in seconds; default 7 days)
AUTH_TOKEN_TTL_SECONDS=604800

# Patrol device gateway: fake | sdk
DEVICE_GATEWAY=fake
DEVICE_ADAPTER_BASE_URL=http://127.0.0.1:8050/api/v1/device-adapter
DEVICE_ADAPTER_API_TOKEN=
DEVICE_ADAPTER_TIMEOUT_SECONDS=10

# GPRS/TCP listener → Django ingest (shared secret)
PATROL_INGEST_API_TOKEN=change-me-ingest-token

# Live monitoring (seconds)
LIVE_MONITORING_STALE_SECONDS=900
LIVE_MONITORING_RECENT_SCAN_LIMIT=30

# Production-only (set DJANGO_ENV=production)
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
